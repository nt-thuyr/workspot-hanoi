# Supabase Configuration (Cloud)
# Supabase URL - Lấy từ Supabase Dashboard > Settings > API > Project URL
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Service Role Key - Lấy từ Supabase Dashboard > Settings > API > service_role secret
# ⚠️ KHÔNG BAOGIỜ share key này công khai!
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Server Port
PORT=3000
# ── Email (SMTP) Configuration ──────────────────────────────────────────────
# Dùng Gmail: bật "App Password" tại https://myaccount.google.com/apppasswords
# (Tắt 2FA → bật 2FA → tạo App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password